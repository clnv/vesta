layout {
    default_tab_template {
        pane size=1 borderless=true {
            plugin location="tab-bar"
        }
        children
        pane size=1 borderless=true {
            plugin location="status-bar"
        }
    }

    tab name="dev" {
        pane split_direction="vertical" {
            pane name="api" command="go" {
                args "run" "./cmd/api" "-config" "config.dev.yml"
            }
            pane name="web" command="npm" {
                args "run" "dev"
            }
        }
    }
    tab name="services" {
        pane name="compose logs" command="docker" {
            args "compose" "--file" "build/dev/compose.yml" "logs" "--follow" "--tail" "100"
        }
    }
}
